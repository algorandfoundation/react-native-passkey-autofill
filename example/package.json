    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "dependencies": {
    "@algorandfoundation/keystore": "^1.0.0-canary.12",
    "@algorandfoundation/react-native-keystore": "^1.0.0-canary.6",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@tanstack/react-store": "^0.9.1",
    "@tanstack/store": "^0.9.1",
    "buffer": "^6.0.3",
    "expo": "~55.0.2",
    "react": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-nitro-modules": "0.35.0",
    "react-native-passkey": "^3.3.2",
    "@algorandfoundation/react-native-passkey-autofill": "..",
    "react-native-quick-crypto": "^1.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "jest": "^29.7.0",
