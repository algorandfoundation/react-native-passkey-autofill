{
  "name": "@algorandfoundation/react-native-passkey-autofill",
  "version": "1.0.0-canary.15",
  "description": "Passkey AutoFill React Native",
  "keywords": [
    "@algorandfoundation/react-native-passkey-autofill",
    "ReactNativePasskeyAutofill",
    "expo",
    "react-native"
  ],
  "homepage": "https://github.com/algorandfoundation/react-native-passkey-autofill#readme",
  "bugs": {
    "url": "https://github.com/algorandfoundation/react-native-passkey-autofill/issues"
  },
  "license": "Apache-2.0",
  "author": "Algorand Foundation",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/algorandfoundation/react-native-passkey-autofill.git"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "CI=true expo-module test",
    "test:android": "cd example/android && ./gradlew :algorandfoundation-react-native-passkey-autofill:testDebugUnitTest --no-daemon",
    "test:android:instrumented": "cd example/android && ./gradlew :algorandfoundation-react-native-passkey-autofill:connectedDebugAndroidTest --no-daemon",
    "test:all": "pnpm run test && pnpm run test:android",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android",
    "appium": "appium --base-path / --log-level warn",
    "appium:setup": "pnpm run appium:setup:android && pnpm run appium:setup:ios",
    "appium:setup:android": "appium driver list --installed 2>&1 | grep -q uiautomator2 || appium driver install uiautomator2",
    "appium:setup:ios": "appium driver list --installed 2>&1 | grep -q xcuitest || appium driver install xcuitest",
    "e2e:build:android": "cd example && expo run:android --variant release --no-install --no-bundler",
    "e2e:build:ios": "cd example && expo run:ios --configuration Release --no-install --no-bundler",
    "e2e:android": "start-server-and-test appium http-get://127.0.0.1:4723/status \"pnpm --filter @algorandfoundation/react-native-passkey-autofill-e2e run test:android\"",
    "e2e:ios": "start-server-and-test appium http-get://127.0.0.1:4723/status \"pnpm --filter @algorandfoundation/react-native-passkey-autofill-e2e run test:ios\""
  },
  "dependencies": {
    "@algorandfoundation/react-native-keystore": "^1.0.0-canary.9"
  },
  "devDependencies": {
    "@expo/config-plugins": "^9.0.0",
    "@expo/npm-proofread": "^1.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/react": "~19.1.1",
    "appium": "^2.11.4",
    "appium-uiautomator2-driver": "^3.9.6",
    "appium-xcuitest-driver": "^9.10.5",
    "expo": "^55.0.1",
    "expo-module-scripts": "^55.0.2",
    "jest": "^29.7.0",
    "lefthook": "2.1.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "react-native": "0.82.1",
    "semantic-release": "^25.0.3",
    "start-server-and-test": "^2.0.8",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "webdriverio": "^9.2.2"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.test.ts"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
