{
  "name": "@algorandfoundation/react-native-passkey-autofill",
  "version": "1.0.0-canary.15",
  "description": "Passkey AutoFill React Native",
  "keywords": [
    "@algorandfoundation/react-native-passkey-autofill",
    "ReactNativePasskeyAutofill",
    "expo",
    "react-native"
  ],
  "homepage": "https://github.com/algorandfoundation/react-native-passkey-autofill#readme",
  "bugs": {
    "url": "https://github.com/algorandfoundation/react-native-passkey-autofill/issues"
  },
  "license": "Apache-2.0",
  "author": "Algorand Foundation",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/algorandfoundation/react-native-passkey-autofill.git"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "CI=true expo-module test",
    "test:android": "cd example/android && ./gradlew :algorandfoundation-react-native-passkey-autofill:testDebugUnitTest --no-daemon",
    "test:android:instrumented": "cd example/android && ./gradlew :algorandfoundation-react-native-passkey-autofill:connectedDebugAndroidTest --no-daemon",
    "test:all": "pnpm run test && pnpm run test:android",
    "prepublishOnly": "expo-module prepublishOnly",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android",
    "appium:start": "appium --base-path / --log-level warn",
    "appium:setup": "pnpm run appium:setup:android && pnpm run appium:setup:ios",
    "appium:setup:android": "appium driver list --installed 2>&1 | grep -q uiautomator2 || appium driver install uiautomator2",
    "appium:setup:ios": "appium driver list --installed 2>&1 | grep -q xcuitest || appium driver install xcuitest",
    "e2e:build:android": "cd example && expo run:android --variant release --no-install --no-bundler",
    "e2e:build:ios": "cd example && expo run:ios --configuration Release --no-install --no-bundler",
    "e2e:android": "export PATH=$PATH:$ANDROID_HOME/platform-tools && start-server-and-test appium:start http-get://127.0.0.1:4723/status \"pnpm --filter @algorandfoundation/react-native-passkey-autofill-e2e run test:android\"",
    "e2e:ios": "start-server-and-test appium:start http-get://127.0.0.1:4723/status \"pnpm --filter @algorandfoundation/react-native-passkey-autofill-e2e run test:ios\""
  },
  "dependencies": {
    "@algorandfoundation/react-native-keystore": "1.0.0-canary.11"
  },
  "devDependencies": {
    "@expo/config-plugins": "~55.0.8",
    "@expo/npm-proofread": "^1.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.17",
    "@types/react": "~19.2.10",
    "appium": "^2.19.0",
    "appium-uiautomator2-driver": "^3.10.0",
    "appium-xcuitest-driver": "^9.10.5",
    "eslint": "^9.39.4",
    "expo": "~55.0.17",
    "expo-doctor": "^1.18.19",
    "expo-module-scripts": "^55.0.2",
    "jest": "^29.7.0",
    "lefthook": "2.1.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.3",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "semantic-release": "^25.0.3",
    "start-server-and-test": "^2.1.5",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "webdriverio": "^9.27.0"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.test.ts"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "@appium/support@<=7.0.5": ">=7.0.6",
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "@xmldom/xmldom": "0.8.13",
      "eslint": "^9.7.0",
      "prettier": "^3.0.0",
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "react-test-renderer": "19.2.0",
      "@types/react": "~19.2.10",
      "react-native-mmkv": "4.3.1",
      "react-native-nitro-modules": "0.35.5",
      "react-native-quick-crypto": "1.0.19",
      "expo": "55.0.17",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "axios@>=1.0.0 <1.12.0": ">=1.12.0",
      "axios@>=1.0.0 <1.15.0": ">=1.15.0",
      "axios@>=1.0.0 <=1.13.4": ">=1.13.5",
      "basic-ftp@<=5.2.2": ">=5.3.0",
      "diff@>=6.0.0 <8.0.3": ">=8.0.3",
      "fast-xml-parser@<5.7.0": ">=5.7.0",
      "form-data@>=4.0.0 <4.0.4": ">=4.0.4",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "on-headers@<1.1.0": ">=1.1.0",
      "path-to-regexp@<0.1.13": "0.1.13",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "postcss@<8.5.10": ">=8.5.10",
      "qs@<6.14.1": ">=6.14.1",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "uuid@<14.0.0": ">=14.0.0",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "yauzl@=3.2.0": ">=3.2.1"
    }
  }
}
